{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "neon-serpents-global",
  "main": "src/worker.js",
  "compatibility_date": "2026-07-17",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "LOBBY",
        "class_name": "GlobalLobby"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["GlobalLobby"]
    }
  ]
}
